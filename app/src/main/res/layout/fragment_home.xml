<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".HomeFragment">

    <!-- OpenStreetMap MapView -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Search Box (Origin and Destination) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/search_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Origin -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/presence_online"
                    app:tint="@color/primary_blue"
                    tools:ignore="ContentDescription" />

                <EditText
                    android:id="@+id/et_origin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@android:color/transparent"
                    android:hint="@string/origin_hint"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:textColor="#2D3139"
                    android:textColorHint="#99A3AD"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="36dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:background="#E5E7EB" />

            <!-- Destination -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/presence_busy"
                    app:tint="#E53935"
                    tools:ignore="ContentDescription" />

                <EditText
                    android:id="@+id/et_destination"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@android:color/transparent"
                    android:hint="@string/destination_hint"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:textColor="#2D3139"
                    android:textColorHint="#99A3AD"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Sidebar Buttons -->
    <LinearLayout
        android:id="@+id/sidebar_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:gravity="end"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_container">

        <!-- Login Button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_open_login"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/primary_blue"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/white"
                tools:ignore="ContentDescription" />
        </androidx.cardview.widget.CardView>

        <!-- User Info -->
        <androidx.cardview.widget.CardView
            android:id="@+id/user_info_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">
            <TextView
                android:id="@+id/tv_user_name_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="@string/user_demo"
                android:textColor="#2D3139"
                android:textSize="14sp" />
        </androidx.cardview.widget.CardView>

        <!-- Logout Button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_logout"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="#FFEBEB"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_lock_power_off"
                app:tint="#E53935"
                tools:ignore="ContentDescription" />
        </androidx.cardview.widget.CardView>

        <!-- Fares Button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_fares"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="$"
                android:textColor="#5E636A"
                android:textSize="20sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

        <!-- History Button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_history"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="#5E636A"
                tools:ignore="ContentDescription" />
        </androidx.cardview.widget.CardView>

        <!-- Profile Button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_profile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#5E636A"
                tools:ignore="ContentDescription" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Complaint Floating Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_complaint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:backgroundTint="#E53935"
        android:src="@android:drawable/ic_btn_speak_now"
        app:fabSize="normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/white"
        tools:ignore="ContentDescription" />

</androidx.constraintlayout.widget.ConstraintLayout>